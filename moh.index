<!DOCTYPE html>
<html lang="ar">
<head>
  <meta charset="UTF-8">
  <title>☠️ كشف السيولة الاحترافي</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <style>
    body {
      background: radial-gradient(circle at top, #1a1a1a, #000);
      color: #e8eaed;
      font-family: Tahoma, sans-serif;
      direction: rtl;
      margin: 0;
      padding: 20px 15px;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
    }

    .box {
      background: rgba(255,255,255,0.05);
      padding: 25px;
      border-radius: 14px;
      width: 100%;
      max-width: 400px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.7);
    }

    h1 {
      text-align: center;
      color: #ff4444;
      margin-bottom: 20px;
    }

    input, button {
      width: 100%;
      height: 48px;
      padding: 0 12px;
      border-radius: 10px;
      border: none;
      font-size: 16px;
      box-sizing: border-box;
      margin-bottom: 12px;
    }

    input {
      background: #2b2b2b;
      color: #fff;
    }

    button.calc {
      background: #ff4444;
      color: #000;
      cursor: pointer;
    }

    button.back {
      background: #fbbc04;
      color: #000;
      cursor: pointer;
    }

    .section {
      margin-bottom: 16px;
    }

    .title {
      font-weight: bold;
      margin-bottom: 6px;
      font-size: 15px;
    }

    .green { color: #34c759; }
    .red   { color: #ff3b30; }

    .value {
      font-size: 13.5px;
      line-height: 1.7;
    }

    .max {
      font-weight: bold;
      font-size: 14px;
      text-shadow: 0 0 6px rgba(52,199,89,0.7);
    }

    hr {
      border: none;
      height: 1px;
      background: #333;
      margin: 18px 0;
    }
  </style>
</head>

<body>

<div class="box">
  <h1>☠️ كشف السيولة</h1>

  <input type="number" id="x" placeholder="أدخل X" step="any">
  <input type="number" id="y" placeholder="أدخل Y" step="any">

  <button class="calc" onclick="calcLiquidity()">كشف السيولة</button>

  <div id="results"></div>

  <button class="back" onclick="goHome()">🏠 العودة</button>
</div>

<script>
function goHome() {
  window.location.href = "index.html";
}

function calcLiquidity() {
  const x = parseFloat(document.getElementById("x").value);
  const y = parseFloat(document.getElementById("y").value);

  if (isNaN(x) || isNaN(y)) {
    alert("يرجى إدخال قيم صحيحة");
    return;
  }

  const a = Math.abs(x - y);

  const retracements = [
    0.113,0.146,0.1618,0.176,0.188,0.214,0.236,0.2618,0.276,0.309,
    0.333,0.3618,0.382,0.423,0.447,0.5,0.553,0.577,0.618,0.654,
    0.707,0.723,0.764,0.786,0.809,0.854,0.886
  ];

  const extensions = [1.13,1.272,1.414,1.618,2.24,2.618,3.14];

  let html = `<div class="section"><strong>a = ${a.toFixed(4)}</strong></div><hr>`;

  html += buildSection("⬇️ أسفل X", "red", retracements, l => (x - a * l));
  html += buildSection("⬆️ أعلى X", "green", retracements, l => (x + a * l));
  html += buildExtension("🔥 امتداد أعلى X", "green", extensions, l => (x + a * l));

  html += `<hr>`;

  html += buildSection("⬇️ أسفل Y", "green", retracements, l => (y - a * l));
  html += buildExtension("🔥 امتداد أسفل Y", "green", extensions, l => (y - a * l));

  html += buildSection("⬆️ أعلى Y", "red", retracements, l => (y + a * l));
  html += buildExtension("🔥 امتداد أعلى Y", "red", extensions, l => (y + a * l));

  document.getElementById("results").innerHTML = html;
}

function buildSection(title, color, levels, formula) {
  let html = `<div class="section"><div class="title ${color}">${title}</div>`;
  levels.forEach(l => {
    html += `<div class="value ${color}">${l} → ${formula(l).toFixed(4)}</div>`;
  });
  html += `</div>`;
  return html;
}

function buildExtension(title, color, levels, formula) {
  let html = `<div class="section"><div class="title ${color}">${title}</div>`;
  levels.forEach(l => {
    html += `<div class="value ${color} max">${l} → ${formula(l).toFixed(4)}</div>`;
  });
  html += `</div>`;
  return html;
}
</script>

</body>
</html>
